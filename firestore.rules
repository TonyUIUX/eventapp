rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    // --- Collections ---

    // App Configuration (Public Read, Admin Write)
    match /app_config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if true; // Public profiles are searchable
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Events
    match /events/{eventId} {
      // Anyone can see active events
      allow read: if resource.data.status == 'active' || isOwner(resource.data.userId) || isAdmin();
      
      // Only signed in users can post
      allow create: if isSignedIn();
      
      // Only owner or admin can edit/delete
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Payments (User Read Only their own, Admin Read All)
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn(); // Service writes it, but rules need to allow if triggered by client
      allow update, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin(); // Only system/admin can send notifications
    }

    // Broadcasts (Public Read, Admin Write)
    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Saved Events (User Read/Write their own)
    match /saved_events/{saveId} {
      allow read, write: if isOwner(resource.data.userId);
    }

    // Reports (User Create, Admin Read/Write)
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
