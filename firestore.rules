rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Legacy admin check (isAdmin field or role == 'admin')
    function isAdmin() {
      return isSignedIn() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true);
    }

    // Superadmin: role field ONLY — no email/UID checks in rules
    function isSuperAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'superadmin';
    }

    function isAdminOrSuperAdmin() {
      return isAdmin() || isSuperAdmin();
    }

    // ── Collections ─────────────────────────────────────────────────────────

    // App Configuration (Public Read, Admin/Superadmin Write)
    match /app_config/{document} {
      allow read: if true;
      allow write: if isAdminOrSuperAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if true; // Public profiles
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdminOrSuperAdmin();
      allow delete: if isAdminOrSuperAdmin();
    }

    // Events
    match /events/{eventId} {
      // Public list/read of active events
      allow list: if true;
      allow get: if resource.data.status == 'active'
                    || (isSignedIn() && request.auth.uid == resource.data.get('postedBy', resource.data.get('userId', '')))
                    || isAdminOrSuperAdmin();

      // Superadmin: full write access to any event
      allow write: if isSuperAdmin();

      // Normal signed-in users can create events
      allow create: if isSignedIn();

      // Owner can update/delete their own events
      allow update, delete: if (isSignedIn() &&
                               request.auth.uid == resource.data.get('postedBy', resource.data.get('userId', '')))
                             || isAdminOrSuperAdmin();
    }

    // Payments (User reads own, Admin/Superadmin reads all)
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrSuperAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdminOrSuperAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrSuperAdmin();
      allow write: if isAdminOrSuperAdmin();
    }

    // Broadcasts (Public Read, Admin/Superadmin Write)
    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isAdminOrSuperAdmin();
    }

    // Saved Events (User Read/Write their own)
    match /saved_events/{saveId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // Reports (User Create, Admin/Superadmin Read/Write)
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdminOrSuperAdmin();
    }
  }
}
