rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true);
    }

    // --- Collections ---

    // App Configuration (Public Read, Admin Write)
    match /app_config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if true; // Public profiles
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Events
    // FIX: Use list-compatible rule — don't check resource.data.status in list context
    // Instead, rely on query-level filters (isActive==true, status==active) in the app
    match /events/{eventId} {
      // Allow public list/read of active events — the app always queries with isActive==true & status==active
      allow list: if true;
      allow get: if resource.data.status == 'active' 
                    || (isSignedIn() && request.auth.uid == resource.data.get('postedBy', resource.data.get('userId', '')))
                    || isAdmin();
      
      // Only signed in users can post
      allow create: if isSignedIn();
      
      // Only owner or admin can edit/delete
      allow update, delete: if (isSignedIn() && 
                               request.auth.uid == resource.data.get('postedBy', resource.data.get('userId', '')))
                             || isAdmin();
    }

    // Payments (User Read Only their own, Admin Read All)
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin();
    }

    // Broadcasts (Public Read, Admin Write)
    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Saved Events (User Read/Write their own)
    match /saved_events/{saveId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // Reports (User Create, Admin Read/Write)
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
