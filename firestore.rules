rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true);
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'superadmin';
    }

    function isAdminOrSuperAdmin() {
      return isAdmin() || isSuperAdmin();
    }

    // ── Collections ─────────────────────────────────────────────────────────

    // App Configuration (Public Read, Admin/Superadmin Write)
    match /app_config/{document} {
      allow read: if true;
      allow write: if isAdminOrSuperAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if true; // Public profiles
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Users can update their own profile BUT cannot change
      // privileged fields (role, isAdmin, isVerifiedOrg).
      // Admins/superadmins can update any field.
      allow update: if isAdminOrSuperAdmin() ||
                    (isOwner(userId) &&
                     !request.resource.data.diff(resource.data)
                       .affectedKeys()
                       .hasAny(['role', 'isAdmin', 'isVerifiedOrg']));

      allow delete: if isAdminOrSuperAdmin();
    }

    // Events
    match /events/{eventId} {
      // Public list/read of active events
      allow list: if true;
      allow get: if resource.data.status == 'active'
                    || (isSignedIn() && request.auth.uid == resource.data.get('postedBy', resource.data.get('userId', '')))
                    || isAdminOrSuperAdmin();

      // Superadmin: full write access to any event
      allow write: if isSuperAdmin();

      // Normal signed-in users can create events — but CANNOT self-approve.
      // isActive must be false, status must be pending_payment or under_review,
      // isFeatured must be false. Enforced server-side by EventPostService.
      allow create: if isSignedIn() &&
                    request.resource.data.get('isActive', false) == false &&
                    request.resource.data.get('isFeatured', false) == false &&
                    request.resource.data.get('status', '') in ['pending_payment', 'under_review'] &&
                    request.resource.data.get('postedBy', '') == request.auth.uid;

      // Owner can update/delete their own events (but not change status to active)
      allow update: if isAdminOrSuperAdmin() ||
                    (isSignedIn() &&
                     request.auth.uid == resource.data.get('postedBy', resource.data.get('userId', '')) &&
                     !request.resource.data.diff(resource.data)
                       .affectedKeys()
                       .hasAny(['isActive', 'status', 'isFeatured', 'paymentStatus']));

      allow delete: if (isSignedIn() &&
                       request.auth.uid == resource.data.get('postedBy', resource.data.get('userId', '')))
                    || isAdminOrSuperAdmin();
    }

    // Payments (User reads own, Admin/Superadmin reads all)
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrSuperAdmin();
      allow create: if isSignedIn() &&
                    request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if isAdminOrSuperAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrSuperAdmin();
      allow write: if isAdminOrSuperAdmin();
    }

    // Broadcasts (Public Read, Admin/Superadmin Write)
    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isAdminOrSuperAdmin();
    }

    // Saved Events — fixed: use request.resource.data for create
    match /saved_events/{saveId} {
      // Read: only the owner
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;

      // Create: use request.resource.data (document doesn't exist yet)
      allow create: if isSignedIn() &&
                    request.resource.data.get('userId', '') == request.auth.uid;

      // Update/Delete: only the owner
      allow update, delete: if isSignedIn() &&
                             request.auth.uid == resource.data.userId;
    }

    // Reports (User Create, Admin/Superadmin Read/Write)
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdminOrSuperAdmin();
    }
  }
}
